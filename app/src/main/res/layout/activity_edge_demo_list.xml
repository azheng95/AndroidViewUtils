<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".edgedemo.EdgeDemoListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Edge-to-Edge 示例"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="点击下方按钮查看各种 Edge-to-Edge 配置效果"
            android:textColor="#666666" />

        <!-- 基础示例 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="基础配置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#999999" />

        <Button
            android:id="@+id/btnBasicDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="基础示例 (默认配置)" />

        <Button
            android:id="@+id/btnDarkThemeDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="深色主题示例" />

        <Button
            android:id="@+id/btnAutoThemeDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动主题示例 (跟随系统)" />

        <!-- 高级示例 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="高级配置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#999999" />

        <Button
            android:id="@+id/btnImmersiveDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="沉浸式示例 (内容延伸到系统栏)" />

        <Button
            android:id="@+id/btnImeDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="软键盘适配示例" />

        <Button
            android:id="@+id/btnCustomConfigDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自定义配置示例" />

        <!-- 工具类示例 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="工具类"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#999999" />

        <Button
            android:id="@+id/btnExtensionDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="扩展函数示例" />

        <Button
            android:id="@+id/btnSystemBarsDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统栏工具示例 (显示/隐藏)" />

        <Button
            android:id="@+id/btnNavigationModeDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="导航栏模式检测" />

        <!-- 使用 BaseEdgeActivity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="继承 BaseEdgeActivity"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#999999" />

        <Button
            android:id="@+id/btnBaseActivityDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="BaseEdgeActivity 使用示例" />

    </LinearLayout>
</ScrollView>
