<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- 背景图片（可替换为视频播放器等） -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/demo_bg"
        android:contentDescription="背景" />

    <!-- 渐变遮罩（增强文字可读性） -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:background="@drawable/gradient_center" />

    <!-- 中心提示文字 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="🎬"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:text="点击屏幕切换沉浸式模式"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- 顶部状态信息（沉浸式模式下会被状态栏遮挡，这是预期效果） -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="48dp"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="沉浸式模式 - 内容延伸到系统栏下方"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

    <!-- 底部提示（沉浸式模式下会被导航栏遮挡） -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="适用于视频播放、图片查看、游戏等场景"
        android:textColor="@android:color/white"
        android:textSize="12sp" />

</FrameLayout>
